function createPet(petName) {
  // 1. Наши скрытые переменные-состояния (Сейф)
  let hunger = 50;     // Голод (от 0 до 100)
  let happiness = 50;  // Счастье (от 0 до 100)

  // 2. Возвращаем объект-пульт для управления питомцем
  return {
    
    // Кнопка "Покормить"
    feed: () => {
        hunger = hunger - 20;
        console.log(`${petName} поел! Счастье ${happiness}, Голод: ${hunger}`)
    },

    // Кнопка "Поиграть"
    play: () => {
        hunger = hunger + 10;
        happiness = happiness + 20;
        console.log(`${petName} поиграл! Счастье: ${happiness}, Голод: ${hunger}`)
    },

    // Кнопка "Узнать статус"
    getStatus: () => {
        console.log(`Питомец: ${petName}, Голод: ${hunger}, Счастье: ${happiness}`);
    }
  };
}

// === ТЕСТИРУЕМ ===

// Создаем кота Барсика
const cat = createPet("Барсик");

// Создаем собаку Рекса (обратите внимание, у него будет СВОЙ собственный рюкзак с переменными!)
const dog = createPet("Рекс");

// Играем с Барсиком
cat.getStatus(); // Питомец: Барсик | Голод: 50 | Счастье: 50
cat.play();      // Барсик поиграл! Счастье: 70, Голод: 60
cat.feed();      // Барсик вкусно поел! Голод: 40

// А теперь проверяем Рекса (его показатели не должны были измениться из-за Барсика!)
console.log("--- Проверяем Рекса ---");
dog.getStatus(); // Питомец: Рекс | Голод: 50 | Счастье: 50
